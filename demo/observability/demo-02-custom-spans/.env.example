# AWS OpenTelemetry Distribution (required for CloudWatch export)
OTEL_PYTHON_DISTRO=aws_distro
OTEL_PYTHON_CONFIGURATOR=aws_configurator

# Export Protocol
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp

# CloudWatch destination — replace with your log group and stream
OTEL_EXPORTER_OTLP_LOGS_HEADERS=x-aws-log-group=/agents/travel-agent,x-aws-log-stream=default,x-aws-metric-namespace=bedrock-agentcore

# Agent service name (appears in GenAI Observability dashboard)
OTEL_RESOURCE_ATTRIBUTES=service.name=travel-agent-custom-spans

# Enable agent observability
AGENT_OBSERVABILITY_ENABLED=true

# AWS region
AWS_DEFAULT_REGION=us-east-1

# Bedrock model (optional override)
# BEDROCK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
